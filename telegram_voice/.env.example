# ── Required: voice-note calling (bot) ─────────────────────────────
# From @BotFather in Telegram (/newbot)
TELEGRAM_BOT_TOKEN=YOUR_TOKEN_HERE

# Optional — auto-captured when you send /start to the bot
# TELEGRAM_CHAT_ID=

# ── Voice & speech ──────────────────────────────────────────────────
# Voices: en-US-AriaNeural, en-GB-SoniaNeural, en-US-GuyNeural, fr-FR-DeniseNeural
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+8%
# faster-whisper model: tiny | base | small | medium  (small = CPU sweet spot)
WHISPER_MODEL=small

# ── Optional: custom brain ──────────────────────────────────────────
# Shell command producing the reply on stdout; {text} = user transcript.
# Unset -> tries `claude -p`, then a built-in body-double reply.
# BRAIN_CMD=

# ── Optional: REAL Telegram calls (userbot, call_real.py) ──────────
# From https://my.telegram.org -> API development tools
TG_API_ID=
TG_API_HASH=
# Who Hermes should ring: your @username or numeric user id
CALL_TARGET=

# ── Tier C: LIVE phone call via ElevenLabs Agents + Twilio ─────────
ELEVENLABS_API_KEY=
EL_AGENT_ID=
EL_PHONE_NUMBER_ID=
MY_PHONE_NUMBER=
