# ============================================================================
# Buddy — environment template. Copy to .env and fill in your own keys.
#   cp .env.example .env
# The real .env is gitignored — NEVER commit it.
# ============================================================================

# ── Telegram (from @BotFather: /newbot) ─────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TOKEN_HERE
# TELEGRAM_CHAT_ID=            # auto-captured when you send /start to the bot

# ── OpenAI (mesh agents + Telegram voice brain) ─────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# ── ElevenLabs (live voice-call agent) ──────────────────────────────
ELEVENLABS_API_KEY=
# EL_AGENT_ID=                 # written by setup_elevenlabs.py
# EL_VOICE_ID=cgSgspJ2msm6clMCkdW9

# ── Public tunnel for the ElevenLabs webhooks ───────────────────────
# Secure defaults: Buddy binds to loopback and does not start cloudflared.
BUDDY_BIND_HOST=127.0.0.1
ENABLE_PUBLIC_TUNNEL=0
# LOCAL_HUB_URL=http://192.168.1.10:8484  # optional, for a trusted LAN device
# HUB_PUBLIC_URL=                       # runtime tunnel URL when explicitly enabled

# Generated automatically by start_all.py/start_all_mac.py. Never commit it.
HUB_SECRET=
# Required only when configuring ElevenLabs post-call webhooks. Generate the
# HMAC secret in ElevenLabs and copy it here; unsigned webhooks are rejected.
ELEVENLABS_WEBHOOK_SECRET=
# Raw call transcripts are not stored locally unless explicitly enabled.
STORE_CALL_TRANSCRIPTS=0

# Comma-separated browser origins allowed to call the private hub.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
# Explicit HTTPS callback hosts for remote event subscribers (empty = disabled).
REMOTE_SUBSCRIBER_HOSTS=

# ── Voice & speech ──────────────────────────────────────────────────
TTS_VOICE=en-US-AriaNeural     # en-GB-SoniaNeural, fr-FR-DeniseNeural, ...
TTS_RATE=+8%
WHISPER_MODEL=small            # tiny | base | small | medium

# ── Per-agent Hermes brains (each agent runs on its own local Hermes) ─
# Create the profiles with `hermes profile create <name>` (see README);
# API keys must be >=16 chars (Hermes security minimum).
# BOOKKEEPER_BASE_URL=http://127.0.0.1:8643/v1   # buddybrain (primary brain)
# BOOKKEEPER_API_KEY=buddybrain-local
# BROWSER_BRAIN_URL=http://127.0.0.1:8644/v1     # browserbrain
# BROWSER_BRAIN_KEY=browserbrain-local
# ORCH_BRAIN_URL=http://127.0.0.1:8645/v1        # orchbrain
# ORCH_BRAIN_KEY=                                # or state/orchbrain.key
# All agents fall back to direct gpt-5.6-terra if their Hermes is down.
# BROWSER_MODEL=gpt-5.6-terra
# ORCH_MODEL=gpt-5.6-terra
# BROWSER_API=http://127.0.0.1:8080              # stealth-browser container API

# ── Optional: custom brain for the Telegram bridge ──────────────────
# BRAIN_CMD=                   # argv template; {text} = transcript. No shell syntax.

# ── Optional: REAL Telegram p2p calls (call_real.py) ────────────────
# From https://my.telegram.org -> API development tools
# TG_API_ID=
# TG_API_HASH=
# CALL_TARGET=                 # your @username or numeric id

# ── Optional: LIVE phone call via ElevenLabs + Twilio ───────────────
# EL_PHONE_NUMBER_ID=
# MY_PHONE_NUMBER=
